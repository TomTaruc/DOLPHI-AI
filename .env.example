# App
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
NODE_ENV=development
PORT=3000

# Database / Supabase PostgreSQL
# DATABASE_URL is required
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Auth / Firebase
# Firebase Admin currently uses firebase-applet-config.json projectId.

# AI Providers
# GEMINI_API_KEY is required for embeddings and Gemini generation
GEMINI_API_KEY=
CHAT_MODEL=gemini-flash-lite-latest
EMBEDDING_MODEL=gemini-embedding-2-preview

# Optional fallback providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PRIMARY_PROVIDER=gemini
FALLBACK_PROVIDER_1=openai
FALLBACK_PROVIDER_2=claude
EMERGENCY_PROVIDER=gemini15

# Knowledge Base
# ADMIN_EMAILS is required to use /api/knowledge/reindex
# KNOWLEDGE_DIR is optional; default is root knowledge/
KNOWLEDGE_DIR=
ADMIN_EMAILS=

# Vector Migration
# Set to true only in development if you are okay deleting indexed chunks and cache on dimension mismatch
ALLOW_VECTOR_RESET=false

# Uploads
UPLOAD_DIR=

